--Find Highest Salary in Each Department

if OBJECT_ID('tempdb..#Employee') is not null
	drop table #Employee

CREATE TABLE #Employee
(
    EmployeeId INT PRIMARY KEY,
    EmployeeName VARCHAR(100),
    DepartmentName VARCHAR(50),
    Salary DECIMAL(10,2)
);

